{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://house-protocols.dev/schemas/v0.2/memory-policy-decision.schema.json",
  "title": "Memory Policy Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "decision_id", "operation", "subject_id", "resource_ref", "source_class", "decision", "reason_codes", "evidence_refs", "decided_at"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "decision_id": { "$ref": "common.schema.json#/$defs/id" },
    "operation": { "type": "string", "enum": ["read", "write", "promote", "quarantine", "redact", "delete", "restore", "export"] },
    "subject_id": { "$ref": "common.schema.json#/$defs/id" },
    "resource_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "source_class": {
      "type": "string",
      "enum": ["authenticated_user", "public_external", "private_external", "tool_observation", "system_derived", "model_generated", "imported_unknown"]
    },
    "decision": { "type": "string", "enum": ["allow", "deny", "quarantine", "redact", "confirm"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/id" }
    },
    "confirmation_ref": { "$ref": "common.schema.json#/$defs/id" },
    "decided_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "policy_version": { "type": "string", "minLength": 1, "maxLength": 80 },
    "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "extensions": { "type": "object" }
  }
}
