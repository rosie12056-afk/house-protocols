{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://house-protocols.dev/schemas/v0.2/scheduler-lease.schema.json",
  "title": "Scheduler Lease",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "lease_id", "work_ref", "holder_id", "status", "acquired_at", "expires_at", "fencing_token"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "lease_id": { "$ref": "common.schema.json#/$defs/id" },
    "work_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "holder_id": { "$ref": "common.schema.json#/$defs/id" },
    "status": { "type": "string", "enum": ["active", "released", "expired"] },
    "acquired_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "released_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "fencing_token": { "type": "integer", "minimum": 1 },
    "previous_lease_id": { "$ref": "common.schema.json#/$defs/id" },
    "extensions": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "released" } }, "required": ["status"] },
      "then": { "properties": { "released_at": true }, "required": ["released_at"] }
    }
  ]
}
