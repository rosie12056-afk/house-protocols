{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://house-protocols.dev/schemas/v0.2/record-lifecycle.schema.json",
  "title": "Record Lifecycle Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "lifecycle_id", "record_ref", "action", "actor_id", "occurred_at", "reason_codes", "evidence_refs"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "lifecycle_id": { "$ref": "common.schema.json#/$defs/id" },
    "record_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "action": { "type": "string", "enum": ["supersede", "soft_delete", "restore"] },
    "actor_id": { "$ref": "common.schema.json#/$defs/id" },
    "occurred_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "replacement_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "previous_lifecycle_id": { "$ref": "common.schema.json#/$defs/id" },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,119}$" }
    },
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/id" }
    },
    "extensions": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "action": { "const": "supersede" } }, "required": ["action"] },
      "then": { "properties": { "replacement_ref": true }, "required": ["replacement_ref"] }
    },
    {
      "if": { "properties": { "action": { "const": "restore" } }, "required": ["action"] },
      "then": { "properties": { "previous_lifecycle_id": true }, "required": ["previous_lifecycle_id"] }
    },
    {
      "if": { "properties": { "action": { "const": "soft_delete" } }, "required": ["action"] },
      "then": { "not": { "required": ["replacement_ref"] } }
    }
  ]
}
