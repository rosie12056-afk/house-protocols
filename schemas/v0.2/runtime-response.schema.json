{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://house-protocols.dev/schemas/v0.2/runtime-response.schema.json",
  "title": "Runtime Response",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "ok", "result"],
      "properties": {
        "protocol_version": { "const": "0.2" },
        "request_id": { "oneOf": [{ "$ref": "common.schema.json#/$defs/id" }, { "type": "null" }] },
        "ok": { "const": true },
        "result": {}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "ok", "error"],
      "properties": {
        "protocol_version": { "const": "0.2" },
        "request_id": { "oneOf": [{ "$ref": "common.schema.json#/$defs/id" }, { "type": "null" }] },
        "ok": { "const": false },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "pattern": "^E_[A-Z0-9_]+$", "maxLength": 120 },
            "message": { "type": "string", "minLength": 1, "maxLength": 500 }
          }
        }
      }
    }
  ]
}
