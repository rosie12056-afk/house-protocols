{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://house-protocols.dev/schemas/v0.2/evidence.schema.json",
  "title": "Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "bundle_id", "created_at", "claims", "evidence"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "bundle_id": { "$ref": "common.schema.json#/$defs/id" },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "claim_type", "statement"],
        "properties": {
          "claim_id": { "$ref": "common.schema.json#/$defs/id" },
          "claim_type": { "type": "string", "enum": ["model_output", "external_fact", "action_result", "interpretation"] },
          "statement": { "type": "string", "minLength": 1, "maxLength": 8000 },
          "truth_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "status": { "type": "string", "enum": ["unverified", "supported", "disputed", "superseded"] }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "supports_claim_ids", "evidence_type", "source_ref", "observed_at"],
        "properties": {
          "evidence_id": { "$ref": "common.schema.json#/$defs/id" },
          "supports_claim_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "$ref": "common.schema.json#/$defs/id" }
          },
          "evidence_type": { "type": "string", "enum": ["model_output", "source_document", "external_observation", "tool_result", "artifact", "human_attestation"] },
          "source_ref": { "$ref": "common.schema.json#/$defs/reference" },
          "observed_at": { "$ref": "common.schema.json#/$defs/timestamp" },
          "retrieval_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "excerpt_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "notes": { "type": "string", "maxLength": 2000 }
        }
      }
    },
    "supersedes_bundle_id": { "$ref": "common.schema.json#/$defs/id" },
    "extensions": { "type": "object" }
  }
}
