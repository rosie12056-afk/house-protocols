{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://house-protocols.dev/schemas/v0.2/lifecycle-opportunity.schema.json",
  "title": "Lifecycle Opportunity",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "opportunity_id", "subject_id", "opportunity_type", "status", "window_start", "window_end", "created_at", "reason_codes", "source_refs"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "opportunity_id": { "$ref": "common.schema.json#/$defs/id" },
    "subject_id": { "$ref": "common.schema.json#/$defs/id" },
    "opportunity_type": { "type": "string", "enum": ["tick", "journal", "dream", "handoff", "feedback"] },
    "status": { "type": "string", "enum": ["offered", "accepted", "declined", "expired"] },
    "window_start": { "$ref": "common.schema.json#/$defs/timestamp" },
    "window_end": { "$ref": "common.schema.json#/$defs/timestamp" },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,119}$" }
    },
    "source_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/reference" }
    },
    "response_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "extensions": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "accepted" } }, "required": ["status"] },
      "then": { "properties": { "response_ref": true }, "required": ["response_ref"] }
    }
  ]
}
