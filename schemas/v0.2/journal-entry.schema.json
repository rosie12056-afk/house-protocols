{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://house-protocols.dev/schemas/v0.2/journal-entry.schema.json",
  "title": "Journal Entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "journal_id", "subject_id", "period_start", "period_end", "events", "reflections", "intentions", "created_at"],
  "properties": {
    "protocol_version": { "const": "0.2" },
    "journal_id": { "$ref": "common.schema.json#/$defs/id" },
    "subject_id": { "$ref": "common.schema.json#/$defs/id" },
    "period_start": { "$ref": "common.schema.json#/$defs/timestamp" },
    "period_end": { "$ref": "common.schema.json#/$defs/timestamp" },
    "events": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entry_id", "statement", "epistemic_status", "source_refs", "evidence_refs"],
        "properties": {
          "entry_id": { "$ref": "common.schema.json#/$defs/id" },
          "statement": { "type": "string", "minLength": 1, "maxLength": 4000 },
          "epistemic_status": { "type": "string", "enum": ["observed", "reported", "inferred", "imagined"] },
          "source_refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/reference" } },
          "evidence_refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/id" } }
        }
      }
    },
    "reflections": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reflection_id", "body", "source_refs"],
        "properties": {
          "reflection_id": { "$ref": "common.schema.json#/$defs/id" },
          "body": { "type": "string", "minLength": 1, "maxLength": 8000 },
          "source_refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/reference" } }
        }
      }
    },
    "intentions": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intention_id", "body", "status"],
        "properties": {
          "intention_id": { "$ref": "common.schema.json#/$defs/id" },
          "body": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "status": { "type": "string", "enum": ["open", "deferred", "declined"] }
        }
      }
    },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "extensions": { "type": "object" }
  }
}
